@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AdaPET | Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        :root {
            --primary-color: #2563eb;
            --secondary-color: #10b981;
            --dark-text: #1e293b;
            --light-bg: #f8fafc;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--light-bg);
            color: var(--dark-text);
            margin: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Navbar Styling */
        .navbar {
            background-color: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #e2e8f0;
        }

        .navbar-brand {
            font-weight: 700;
            color: var(--primary-color) !important;
            font-size: 1.5rem;
        }

        /* Hero Section */
        .hero-section {
            flex: 1;
            display: flex;
            align-items: center;
            padding: 80px 0;
            background: radial-gradient(circle at top right, #e2e8f0 0%, #f8fafc 50%);
        }

        .hero-title {
            font-size: 3.5rem;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 1.5rem;
        }

            .hero-title span {
                color: var(--primary-color);
            }

        .hero-subtitle {
            font-size: 1.1rem;
            color: #64748b;
            margin-bottom: 2.5rem;
            max-width: 500px;
        }

        /* Buttons Styling */
        .btn-custom {
            padding: 12px 35px;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-decoration: none;
            display: inline-block;
        }

        .btn-login {
            background-color: var(--primary-color);
            color: white;
            border: none;
            box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
        }

            .btn-login:hover {
                background-color: #1d4ed8;
                transform: translateY(-2px);
                color: white;
            }

        .btn-signup {
            background-color: transparent;
            color: var(--secondary-color);
            border: 2px solid var(--secondary-color);
            margin-left: 15px;
        }

            .btn-signup:hover {
                background-color: var(--secondary-color);
                color: white;
                transform: translateY(-2px);
            }

        /* Hero Image Container */
        .img-container {
            position: relative;
            text-align: center;
        }

        .hero-img {
            width: 100%;
            max-width: 500px;
            height: 500px;
            object-fit: cover;
            border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            animation: morph 8s ease-in-out infinite;
        }

        @@keyframes morph {
            0% {
                border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
            }

            50% {
                border-radius: 50% 50% 30% 70% / 50% 60% 40% 50%;
            }

            100% {
                border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
            }
        }

        /* Footer */
        footer {
            padding: 20px 0;
            background-color: white;
            border-top: 1px solid #e2e8f0;
            font-size: 0.9rem;
            color: #94a3b8;
        }

        /* Alert styling */
        .alert-logout {
            position: fixed;
            top: 80px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1000;
            min-width: 300px;
            text-align: center;
            animation: slideDown 0.5s ease;
        }

        @@keyframes slideDown {
            from {
                top: 0;
                opacity: 0;
            }

            to {
                top: 80px;
                opacity: 1;
            }
        }

        /* Responsive Adjustments */
        @@media (max-width: 991px) {
            .hero-title {
                font-size: 2.5rem;
            }

            .hero-section {
                text-align: center;
                padding: 40px 0;
            }

            .hero-subtitle {
                margin-left: auto;
                margin-right: auto;
            }

            .btn-signup {
                margin-left: 0;
                margin-top: 10px;
            }

            .img-container {
                margin-top: 50px;
            }

            .hero-img {
                height: 350px;
            }
        }
    </style>
</head>
<body>

    <!-- ✅ Logout Success Message -->
    @if (ViewBag.LogoutMessage != null)
    {
        <div class="alert alert-info alert-dismissible fade show alert-logout" role="alert" id="logoutAlert">
            <i class="fas fa-sign-out-alt"></i> @ViewBag.LogoutMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">🐾 AdaPET</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link px-3" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="/Home/Privacy">Privacy</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="hero-title">Your Pet's <span>Happiness</span> Starts Here</h1>
                    <p class="hero-subtitle">
                        Join our community to adopt a new friend, find expert veterinary services,
                        and give every pet the loving home they deserve.
                    </p>
                    <div class="d-flex flex-column flex-sm-row">
                        <a href="/Account/Login" class="btn btn-custom btn-login">Login to Account</a>
                        <a href="/Account/Register" class="btn btn-custom btn-signup">Create Account</a>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="img-container">
                        <img src="https://images.unsplash.com/photo-1544568100-847a948585b9?q=80&w=1000&auto=format&fit=crop"
                             alt="Happy Pets" class="hero-img">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="text-center">
        <div class="container">
            &copy; 2026 - AdaPET - <a href="/Home/Privacy" class="text-decoration-none text-muted">Privacy Policy</a>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Auto-hide the logout alert after 5 seconds
        setTimeout(function() {
            var alert = document.getElementById('logoutAlert');
            if (alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            }
        }, 5000);

        // Remove the query parameter from URL without refreshing
        if (window.location.search.includes('logout=success') || window.location.search.includes('deleted=success')) {
            const newUrl = window.location.pathname;
            window.history.replaceState({}, document.title, newUrl);
        }
    </script>
</body>
</html>