@model AdaPET.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "New account";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0"><i class="fas fa-user-plus me-2"></i>Create New Account</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Register" method="post" id="registerForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row">
                        <!-- الحقول الأساسية -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Full Name</label>
                            <input asp-for="Name" class="form-control" placeholder="John Doe" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                            <input asp-for="Email" class="form-control" dir="ltr" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label fw-bold">Phone Number</label>
                            <input asp-for="Phone" class="form-control" dir="ltr" placeholder="010XXXXXXXX" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="UserRole" class="form-label fw-bold text-primary">Account Type</label>
                            <select asp-for="UserRole" class="form-select border-primary" id="roleSelect">
                                <option value="User">Pet Owner (User)</option>
                                <option value="Doctor">Veterinary Doctor</option>
                            </select>
                            <span asp-validation-for="UserRole" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label fw-bold">Password</label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="********" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold">Confirm Password</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="********" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- حقول الطبيب -->
                    <div id="doctorFields" style="display: none;" class="mt-3 p-3 border border-info rounded bg-light">
                        <div class="mb-4">
                            <label asp-for="Specialization" class="form-label fw-bold text-info">Specialization</label>
                            <input asp-for="Specialization" class="form-control" id="Specialization" placeholder="e.g. Surgery, General Practice" />
                            <span asp-validation-for="Specialization" class="text-danger small"></span>
                            <span id="specializationError" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold mb-2">Clinics Information <span class="text-danger">*</span></label>
                            <div id="clinicsContainer">
                                <div class="row g-2 mb-2 clinic-row">
                                    <div class="col-md-5">
                                        <input type="text" name="Clinics[0].Name" class="form-control clinic-name" placeholder="Clinic Name" />
                                        <span class="clinic-name-error text-danger small"></span>
                                    </div>
                                    <div class="col-md-5">
                                        <input type="text" name="Clinics[0].Address" class="form-control clinic-address" placeholder="Clinic Address" />
                                        <span class="clinic-address-error text-danger small"></span>
                                    </div>
                                    <div class="col-md-2">
                                        <!-- زر الحذف سيظهر للعيادات الإضافية فقط -->
                                    </div>
                                </div>
                            </div>
                            <span id="clinicsGlobalError" class="text-danger small d-block mt-1"></span>
                            <button type="button" id="addClinicBtn" class="btn btn-sm btn-outline-info mt-2">+ Add Another Clinic</button>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">Create Account</button>
                        <div class="text-center mt-3">
                            <a asp-action="Login" class="text-secondary text-decoration-none small">Already have an account? Log in</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <!-- ✅ ملفاتك الخاصة -->
    <script src="~/js/doctor-validation.js"></script>
    <script src="~/js/register.js"></script>
}
