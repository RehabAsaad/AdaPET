@model AdaPET.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "New account";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4>Create new account</h4>
            </div>
            <div class="card-body">
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group mb-3">
                        <label asp-for="Name">Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Email">Email</label>
                        <input asp-for="Email" class="form-control" dir="ltr" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Phone">Phone Number </label>
                        <input asp-for="Phone" class="form-control" dir="ltr" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Password">Password</label>
                        <input asp-for="Password" class="form-control" type="password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="ConfirmPassword">Confirm Password</label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="UserRole">User Role</label>
                        <select asp-for="UserRole" class="form-control" id="UserRole">
                            <option value="User">User</option>
                            <option value="Doctor">Doctor</option>
                        </select>
                        <span asp-validation-for="UserRole" class="text-danger"></span>
                    </div>

                    <div id="doctorFields" style="display: none;">
                        <div class="form-group mb-3">
                            <label asp-for="Specialization">Specialization</label>
                            <input asp-for="Specialization" class="form-control" />
                        </div>

                        <div class="form-group mb-3">
                            <label>Clinics</label>
                            <div id="clinicsContainer">
                                <div class="clinic-entry mb-2">
                                    <input type="text" name="Clinics[0].Name" class="form-control mb-1" placeholder="Clinic Name" />
                                    <input type="text" name="Clinics[0].Address" class="form-control" placeholder="Clinic Location " />
                                </div>
                            </div>
                            <button type="button" id="addClinicBtn" class="btn btn-sm btn-secondary">+ Add another Clinic</button>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">Register</button>
                    <a asp-action="Login" class="btn btn-secondary">have an account! log in</a>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('UserRole').addEventListener('change', function () {
        var doctorFields = document.getElementById('doctorFields');
        doctorFields.style.display = this.value === 'Doctor' ? 'block' : 'none';
    });

    var clinicIndex = 1;
    document.getElementById('addClinicBtn')?.addEventListener('click', function () {
        var container = document.getElementById('clinicsContainer');
        var newEntry = document.createElement('div');
        newEntry.className = 'clinic-entry mb-2';
        newEntry.innerHTML = `
                <input type="text" name="Clinics[${clinicIndex}].Name" class="form-control mb-1" placeholder="اسم العيادة" />
                <input type="text" name="Clinics[${clinicIndex}].Address" class="form-control" placeholder="عنوان العيادة" />
                <button type="button" class="btn btn-sm btn-danger mt-1 removeClinicBtn">حذف</button>
            `;
        container.appendChild(newEntry);
        clinicIndex++;

        newEntry.querySelector('.removeClinicBtn').addEventListener('click', function () {
            newEntry.remove();
        });
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}