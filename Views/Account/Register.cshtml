@model User
@{
    ViewData["Title"] = "Sign Up - AdaPET";
}

<!-- استدعاء الستايلات -->
<link rel="stylesheet" href="~/css/register.css" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 shadow-sm p-4 border rounded bg-light">
            <h2 class="text-center text-primary fw-bold mb-4">Create Your Account</h2>

            <form asp-action="Register" method="post" id="registerForm">

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Full Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter your name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="example@mail.com" autocomplete="off" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="phone" class="form-label fw-bold">Phone Number</label>
                    <input asp-for="phone" class="form-control" placeholder="01xxxxxxxxx" />
                    <span asp-validation-for="phone" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-bold">Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="********" id="Password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmPass" class="form-label fw-bold">Confirm Password</label>
                    <input asp-for="ConfirmPass" type="password" class="form-control" placeholder="********" />
                    <span asp-validation-for="ConfirmPass" class="text-danger small"></span>
                </div>

                <hr />

                <div class="mb-3">
                    <label class="form-label fw-bold text-info">Account Type</label>
                    <select id="roleSelect" name="UserRole" class="form-select border-info">
                        <option value="Patient">Pet Owner (User)</option>
                        <option value="Doctor">Veterinary Doctor</option>
                    </select>
                </div>

                <!-- حقول الدكتور -->
                <div id="doctorFields" class="mb-3 p-3 border border-warning rounded" style="display: none; background-color: #fffdec;">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-warning">Specialization <span class="text-danger">*</span></label>
                        <input type="text" id="Specialization" name="Specialization" class="form-control" placeholder="e.g., Surgery, Dermatology, Cardiology" />
                        <span id="specializationError" class="text-danger small"></span>
                    </div>

                    <hr />
                    <label class="form-label fw-bold">Your Clinics <span class="text-danger">*</span></label>
                    <div id="clinicsContainer">
                        <div class="row g-2 mb-2 clinic-row">
                            <div class="col-md-6">
                                <input type="text" name="ClinicNames" class="form-control clinic-name" placeholder="Clinic Name" />
                                <span class="clinic-name-error text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <input type="text" name="ClinicAddresses" class="form-control clinic-address" placeholder="Clinic Address" />
                                <span class="clinic-address-error text-danger small"></span>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary mt-2" id="addClinicBtn">+ Add Another Clinic</button>
                    <div id="clinicsGlobalError" class="text-danger small mt-2"></div>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-success btn-lg fw-bold">Sign Up Now</button>
                </div>

                <div class="text-center mt-3">
                    <span>Already have an account? </span>
                    <a asp-action="Login" class="text-decoration-none">Log In</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <!-- استدعاء ملفات الجافاسكريبت -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js"></script>
    <script src="~/js/doctor-validation.js"></script>
    <script src="~/js/register.js"></script>
}