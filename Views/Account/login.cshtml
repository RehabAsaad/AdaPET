@{
    Layout = null; // اجعلها null لو تريدينها صفحة مستقلة، أو احذفي السطر لو تستخدمين _Layout
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | AdaPET</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at top right, #e2e8f0 0%, #f8fafc 50%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            background: white;
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
            width: 100%;
            max-width: 400px;
            border: none;
        }

        .login-header h2 {
            font-weight: 700;
            color: #2563eb;
            margin-bottom: 10px;
        }

        .form-label {
            font-weight: 600;
            color: #4b5563;
            font-size: 0.9rem;
        }

        .custom-input {
            border: 2px solid #f1f5f9;
            border-radius: 12px;
            padding: 12px 15px;
            background-color: #f8fafc;
            transition: all 0.3s ease;
        }

            .custom-input:focus {
                border-color: #2563eb;
                background-color: white;
                box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
                outline: none;
            }

        .btn-login {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 12px;
            font-weight: 600;
            margin-top: 10px;
            transition: all 0.3s ease;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(37, 99, 235, 0.3);
                color: white;
            }

        .footer-text {
            font-size: 0.85rem;
            color: #6b7280;
            margin-top: 25px;
        }

            .footer-text a {
                color: #2563eb;
                text-decoration: none;
                font-weight: 600;
            }

        .back-home {
            position: absolute;
            top: 20px;
            left: 20px;
            text-decoration: none;
            color: #64748b;
            font-weight: 500;
        }

        /* تنسيق إضافي لرسائل الخطأ */
        .alert-danger {
            background-color: #fee2e2;
            border-color: #fecaca;
            color: #dc2626;
            border-radius: 12px;
            font-size: 0.85rem;
            padding: 10px 15px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

    <a href="/" class="back-home">← Back to Home</a>

    <div class="login-card">
        <div class="login-header text-center">
            <h2>Welcome Back!🐾</h2>
            <p class="text-muted small">Please enter your details</p>
        </div>

        <!-- ✅ نموذج الدخول بعد التعديل -->
        <form method="post" asp-action="login" asp-controller="Account">
            <!-- ✅ عرض رسائل الخطأ العامة -->
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert">
                <!-- رسالة الخطأ ستظهر هنا تلقائياً -->
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email Address</label>
                <!-- ✅ تم إزالة value="@ViewBag.Email" -->
                <input type="email" name="Email" id="email"
                       class="form-control custom-input"
                       placeholder="name@example.com"
                       autocomplete="off"
                       required>
            </div>

            <div class="mb-4">
                <label for="password" class="form-label">Password</label>
                <input type="password" name="Password" id="password"
                       class="form-control custom-input"
                       placeholder="********"
                       autocomplete="off"
                       required>
                <div class="text-end mt-1">
                    <a asp-action="ForgotPassword" class="small text-muted text-decoration-none">Forgot password?</a>
                </div>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-login shadow-sm">Log In</button>
            </div>

            <div class="text-center footer-text">
                Don't have an account? <a asp-action="Register">Sign up</a>
            </div>
        </form>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>