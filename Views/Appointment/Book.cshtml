@model AdaPET.Models.ViewModels.BookAppointmentViewModel

@{
    ViewData["Title"] = "Book Appointment";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h3>📅 Confirm Your Appointment</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <h5>📍 Appointment Details</h5>
                        <hr />
                        <p><strong>👨‍⚕️ Doctor:</strong> Dr. @Model.DoctorName</p>
                        <p><strong>📅 Date:</strong> @Model.AppointmentDate.ToString("yyyy-MM-dd")</p>
                        <p><strong>⏰ Time:</strong> @Model.StartTime.ToString(@"hh\:mm") - @Model.EndTime.ToString(@"hh\:mm")</p>
                    </div>

                    <form asp-action="Book" method="post">
                        @Html.AntiForgeryToken()

                        <!-- ✅ السطر ده أهم حاجة - ضيفيه -->
                        <input type="hidden" asp-for="TimeSlotId" />

                        <input type="hidden" asp-for="ScheduleId" />
                        <input type="hidden" asp-for="DoctorId" />
                        <input type="hidden" asp-for="DoctorName" />
                        <input type="hidden" asp-for="AppointmentDate" />
                        <input type="hidden" asp-for="StartTime" />
                        <input type="hidden" asp-for="EndTime" />

                        <div class="alert alert-warning">
                            <i class="fas fa-info-circle"></i>
                            Please confirm your booking. You can cancel anytime before the appointment.
                        </div>

                        <div class="d-flex justify-content-between mt-3">
                            <a asp-controller="Doctor" asp-action="Index" class="btn btn-secondary">
                                ← Cancel
                            </a>
                            <button type="submit" class="btn btn-success btn-lg">
                                ✅ Confirm Booking
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>