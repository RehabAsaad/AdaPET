@using System.Security.Claims
@model AdaPET.Models.UserProfileViewModel

@{
    ViewData["Title"] = $"{Model.Name}'s Profile";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container mt-4">
    <div class="row">
        <!-- User Information Card -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header @(Model.UserRole == "Doctor" ? "bg-info" : "bg-primary") text-white">
                    <h4 class="mb-0">
                        @if (Model.UserRole == "Doctor")
                        {
                            <i class="fas fa-user-md"></i>
                            <span> Doctor Profile</span>
                        }
                        else
                        {
                            <i class="fas fa-user"></i>
                            <span> User Profile</span>
                        }
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Profile Photo -->
                    <div class="text-center mb-3">
                        @if (!string.IsNullOrEmpty(Model.PhotoURL))
                        {
                            <img src="@Model.PhotoURL" alt="Profile"
                                 style="width: 100px; height: 100px; object-fit: cover; border-radius: 50%; border: 3px solid white; box-shadow: 0 2px 5px rgba(0,0,0,0.2);" />
                        }
                        else
                        {
                            <div class="rounded-circle @(Model.UserRole == "Doctor" ? "bg-info" : "bg-secondary") text-white d-inline-flex align-items-center justify-content-center"
                                 style="width: 100px; height: 100px; font-size: 40px;">
                                @Model.Name?.Substring(0, 1).ToUpper()
                            </div>
                        }
                    </div>

                    <!-- User Information -->
                    <dl class="row">
                        <dt class="col-sm-4">Name:</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">Email:</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Phone:</dt>
                        <dd class="col-sm-8">@Model.Phone</dd>

                        <dt class="col-sm-4">Role:</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.UserRole == "Doctor" ? "bg-info" : "bg-secondary")">
                                @Model.UserRole
                            </span>
                        </dd>

                        @if (Model.UserRole == "Doctor" && !string.IsNullOrEmpty(Model.Specialization))
                        {
                            <dt class="col-sm-4">Specialization:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-success">@Model.Specialization</span>
                            </dd>
                        }

                        @if (Model.UserRole == "Doctor" && !string.IsNullOrEmpty(Model.ClinicsList))
                        {
                            <dt class="col-sm-4">Clinics:</dt>
                            <dd class="col-sm-8">
                                @foreach (var clinic in Model.ClinicsList.Split(','))
                                {
                                    <span class="badge bg-info me-1 mb-1">@clinic.Trim()</span>
                                }
                            </dd>
                        }
                    </dl>

                    <!-- Buttons Section -->
                    @{
                        // Get the currently logged-in user ID
                        var currentUserIdString = User.FindFirstValue(ClaimTypes.NameIdentifier);
                        int currentUserId = 0;
                        if (!string.IsNullOrEmpty(currentUserIdString))
                        {
                            int.TryParse(currentUserIdString, out currentUserId);
                        }

                        // Check if the profile being viewed belongs to the logged-in user
                        bool isOwnProfile = (currentUserId == Model.UserId);
                    }

                    @if (isOwnProfile)
                    {
                        <div class="text-center mt-3">
                            <!-- Edit Profile Button -->
                            <a asp-action="EditProfile" class="btn btn-warning w-100 mb-2">
                                <i class="fas fa-edit"></i> Edit Profile
                            </a>

                            <!-- Logout Button -->
                            <form asp-action="Logout" method="post" class="d-inline w-100">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-secondary w-100 mb-2">
                                    <i class="fas fa-sign-out-alt"></i> Logout
                                </button>
                            </form>

                            <!-- Delete Account Button (triggers modal) -->
                            <button type="button" class="btn btn-danger w-100" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                <i class="fas fa-trash-alt"></i> Delete Account
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Animals Card -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="fas fa-paw"></i> My Animals (@Model.Animals.Count)
                    </h4>

                    @* Show Add button for OWN profile (both User AND Doctor can add animals now) *@
                    @if (isOwnProfile)
                    {
                        <a asp-controller="Animals" asp-action="Add" class="btn btn-light btn-sm">
                            <i class="fas fa-plus"></i> Add New Animal
                        </a>
                    }
                </div>
                <div class="card-body">
                    @if (Model.Animals.Any())
                    {
                        <div class="row">
                            @foreach (var animal in Model.Animals)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card h-100">
                                        @if (!string.IsNullOrEmpty(animal.ImgURL))
                                        {
                                            <img src="@animal.ImgURL" class="card-img-top" alt="@animal.Name"
                                                 style="height: 200px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-light text-center py-5">
                                                <i class="fas fa-paw fa-3x text-muted"></i>
                                            </div>
                                        }
                                        <div class="card-body">
                                            <h5 class="card-title text-primary">@animal.Name</h5>
                                            <hr />
                                            <dl class="row mb-0">
                                                <dt class="col-sm-4">Type:</dt>
                                                <dd class="col-sm-8">@animal.Type</dd>

                                                <dt class="col-sm-4">Age:</dt>
                                                <dd class="col-sm-8">@animal.Age years</dd>

                                                @if (!string.IsNullOrEmpty(animal.Description))
                                                {
                                                    <dt class="col-sm-4">Description:</dt>
                                                    <dd class="col-sm-8">@animal.Description</dd>
                                                }

                                                <dt class="col-sm-4">Status:</dt>
                                                <dd class="col-sm-8">
                                                    @if (animal.IsAdopted)
                                                    {
                                                        <span class="badge bg-danger">Adopted</span>
                                                        if (animal.AdoptedDate.HasValue)
                                                        {
                                                            <br />
                                                            <small class="text-muted">Adopted: @animal.AdoptedDate.Value.ToString("MMM dd, yyyy")</small>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-success">Available for Adoption</span>
                                                    }
                                                </dd>
                                            </dl>
                                        </div>
                                        <div class="card-footer bg-transparent">
                                            <div class="btn-group w-100" role="group">
                                                <a asp-controller="Animals" asp-action="Details" asp-route-id="@animal.ID"
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-info-circle"></i> View Details
                                                </a>
                                                @if (isOwnProfile)
                                                {
                                                    <a asp-controller="Animals" asp-action="Edit" asp-route-id="@animal.ID"
                                                       class="btn btn-sm btn-outline-warning">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </a>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <i class="fas fa-paw fa-3x mb-3"></i>
                            <h5>No animals registered yet</h5>
                            @if (isOwnProfile)
                            {
                                <p>Click the "Add New Animal" button to add your first pet!</p>
                            }
                            else
                            {
                                <p>This user hasn't registered any animals yet.</p>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Account Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="fas fa-exclamation-triangle"></i> Delete Account
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-3">
                    <i class="fas fa-trash-alt fa-4x text-danger"></i>
                </div>
                <p class="text-center fw-bold">
                    Are you absolutely sure you want to delete your account?
                </p>
                <p class="text-danger text-center">
                    This action <strong>CANNOT</strong> be undone. This will permanently delete:
                </p>
                <ul class="text-danger">
                    <li>Your profile information</li>
                    <li>Your profile photo</li>
                    @if (Model.UserRole == "Doctor")
                    {
                        <li>Your specialization and clinics</li>
                    }
                    <li>All your animals (including their photos)</li>
                </ul>
                <p class="text-center text-muted">
                    Please type <strong class="text-danger">DELETE</strong> to confirm.
                </p>
                <input type="text" id="confirmDeleteInput" class="form-control text-center" placeholder="Type DELETE here" autocomplete="off" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> Cancel
                </button>
                <form asp-action="DeleteAccount" method="post" id="deleteAccountForm">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger" id="confirmDeleteBtn" disabled>
                        <i class="fas fa-trash-alt"></i> Permanently Delete Account
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

    .rounded-circle {
        border: 3px solid white;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }

    /* Badge styling for clinics */
    .badge.bg-info {
        background-color: #17a2b8 !important;
        padding: 5px 10px;
        font-size: 0.85rem;
    }
</style>

<!-- JavaScript for confirmation input -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const confirmInput = document.getElementById('confirmDeleteInput');
        const confirmBtn = document.getElementById('confirmDeleteBtn');

        if (confirmInput && confirmBtn) {
            confirmInput.addEventListener('input', function() {
                if (this.value === 'DELETE') {
                    confirmBtn.disabled = false;
                } else {
                    confirmBtn.disabled = true;
                }
            });
        }
    });
</script>