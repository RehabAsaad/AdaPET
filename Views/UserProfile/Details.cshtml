@using System.Security.Claims
@model AdaPET.Models.UserProfileViewModel

@{
    ViewData["Title"] = $"{Model.Name}'s Profile";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 profile-sidebar">
                <div class="card-header @(Model.UserRole == "Doctor" ? "bg-info" : "bg-primary") text-white py-3 text-center">
                    <h5 class="mb-0">
                        <i class="fas @(Model.UserRole == "Doctor" ? "fa-user-md" : "fa-user")"></i> 
                        @(Model.UserRole == "Doctor" ? "Doctor Profile" : "User Profile")
                    </h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        @if (!string.IsNullOrEmpty(Model.PhotoURL))
                        {
                            <img src="@Model.PhotoURL" alt="Profile"
                                 style="width: 100px; height: 100px; object-fit: cover; border-radius: 50%; border: 3px solid #eee;" />
                        }
                        else
                        {
                            <div class="rounded-circle @(Model.UserRole == "Doctor" ? "bg-info" : "bg-secondary") text-white d-inline-flex align-items-center justify-content-center"
                                 style="width: 100px; height: 100px; font-size: 35px;">
                                @Model.Name?.Substring(0, 1).ToUpper()
                            </div>
                        }
                    </div>

                    <div class="user-details px-2">
                        <p class="mb-2"><strong>Name:</strong> <span class="ms-1">@Model.Name</span></p>
                        <p class="mb-2"><strong>Email:</strong> <span class="ms-1">@Model.Email</span></p>
                        <p class="mb-2"><strong>Phone:</strong> <span class="ms-1">@Model.Phone</span></p>
                        <p class="mb-3"><strong>Role:</strong> <span class="badge @(Model.UserRole == "Doctor" ? "bg-info" : "bg-secondary") ms-1">@Model.UserRole</span></p>
                    </div>

                    <hr />

                    @{
                        var currentUserIdString = User.FindFirstValue(ClaimTypes.NameIdentifier);
                        int currentUserId = 0;
                        if (!string.IsNullOrEmpty(currentUserIdString)) { int.TryParse(currentUserIdString, out currentUserId); }
                        bool isOwnProfile = (currentUserId == Model.UserId);
                    }

                    @if (isOwnProfile)
                    {
                        <div class="d-grid gap-2 px-2">
                            <a asp-action="EditProfile" class="btn btn-warning text-dark fw-bold btn-sm py-2">
                                <i class="fas fa-edit"></i> Edit Profile
                            </a>
                            <form asp-action="Logout" method="post" class="d-grid">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-secondary btn-sm py-2">
                                    <i class="fas fa-sign-out-alt"></i> Logout
                                </button>
                            </form>
                            <button type="button" class="btn btn-outline-danger btn-sm mt-1 border-0" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                <i class="fas fa-trash-alt"></i> Delete Account
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0 animal-section-card">
                <div class="card-header custom-green-header text-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="fas fa-paw"></i> My Animals (@Model.Animals.Count)
                    </h5>
                    @if (isOwnProfile)
                    {
                        <a asp-controller="Animals" asp-action="Add" class="btn btn-light-green btn-sm fw-bold">
                            <i class="fas fa-plus"></i> Add New Animal
                        </a>
                    }
                </div>
                <div class="card-body p-4">
                    @if (Model.Animals.Any())
                    {
                        <div class="row"> 
                            @foreach (var animal in Model.Animals)
                            {
                                <div class="col-md-6 mb-4">
                                    <div class="card border-light shadow-xs h-100 overflow-hidden">
                                        @if (!string.IsNullOrEmpty(animal.ImgURL))
                                        {
                                            <img src="@animal.ImgURL" class="card-img-top" alt="@animal.Name" style="height: 180px; object-fit: cover;">
                                        }
                                        <div class="card-body p-3 d-flex flex-column">
                                            <h5 class="animal-title mb-2">@animal.Name</h5>
                                            <hr class="my-2" />
                                            
                                            <div class="animal-info-row mb-1">
                                                <span class="fw-bold me-2 small">Type:</span>
                                                <span class="text-muted small">@animal.Type</span>
                                            </div>
                                            <div class="animal-info-row mb-1">
                                                <span class="fw-bold me-2 small">Age:</span>
                                                <span class="text-muted small">@animal.Age years</span>
                                            </div>
                                            <div class="animal-info-row mb-2">
                                                <div class="fw-bold small">Description:</div>
                                                <div class="text-muted small text-break">
                                                    @(animal.Description?.Length > 50 ? animal.Description.Substring(0, 50) + "..." : animal.Description)
                                                </div>
                                            </div>
                                            
                                            <div class="mb-3">
                                                @if (animal.IsAdopted)
                                                {
                                                    <span class="badge bg-danger status-badge">Adopted</span>
                                                    @if (animal.AdoptedDate.HasValue)
                                                    {
                                                        <div class="adopted-date">Adopted: @animal.AdoptedDate.Value.ToString("MMM dd, yyyy")</div>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success status-badge">Available</span>
                                                }
                                            </div>
                                            
                                            @if (isOwnProfile)
                                            {
                                                <div class="mt-auto">
                                                    <a asp-controller="Animals" asp-action="Edit" asp-route-id="@animal.ID" class="btn btn-outline-warning w-100 py-1 fw-bold btn-sm">
                                                       <i class="fas fa-edit"></i> Edit
                                                    </a>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="fas fa-paw fa-3x mb-3"></i>
                            <h5>No animals registered yet.</h5>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white border-0">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i> Confirm Deletion
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-4">
                <p class="fw-bold mb-1">Are you sure you want to delete your account?</p>
                <p class="text-muted small">This will delete your profile and all your animal records permanently. This action cannot be undone.</p>
            </div>
            <div class="modal-footer justify-content-center border-0 pb-4">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                
                
                <form asp-controller="UserProfile" asp-action="DeleteAccount" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger px-4">Yes, Delete Account</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* التنسيقات العامة */
    .custom-green-header { background-color: #2e7d32 !important; }
    .btn-light-green { background-color: #e8f5e9 !important; color: #2e7d32 !important; border: none; }
    
    .profile-sidebar { border-radius: 8px; overflow: hidden; }
    .animal-section-card { border-radius: 8px; overflow: hidden; }
    
    .animal-title { color: #0d6efd; font-weight: bold; font-size: 1.2rem; }
    
    .status-badge { 
        padding: 4px 8px; 
        font-size: 0.75rem; 
        border-radius: 4px; 
    }
    
    .adopted-date { 
        font-size: 0.7rem; 
        color: #6c757d; 
        margin-top: 2px;
    }

    .btn-outline-warning { 
        color: #ffc107 !important; 
        border-color: #ffc107 !important; 
        background-color: transparent !important;
    }
    .btn-outline-warning:hover { 
        background-color: #ffc107 !important; 
        color: white !important; 
    }

    /* لضمان تناسق الكروت بجانب بعضها */
    .animal-info-row { display: block; }
</style>