@model AdaPET.Models.ViewModels.DoctorsListViewModel
@{
    ViewData["Title"] = "Doctors and Clinics";
}

<h2>Our Doctors and Their Clinics</h2>

<div class="container mt-4">
    @if (Model.Doctors.Any())
    {
        <div class="row">
            @foreach (var doctor in Model.Doctors)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-primary text-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h4>Dr. @doctor.DoctorName</h4>
                                    <h6>Specialization: @doctor.Specialization</h6>
                                </div>
                                <div>
                                    <!-- ✅ VIEW PROFILE BUTTON -->
                                    <a asp-controller="UserProfile"
                                       asp-action="Details"
                                       asp-route-id="@doctor.DoctorId"
                                       class="btn btn-light btn-sm">
                                        <i class="fas fa-user-circle"></i> View Profile
                                    </a>
                                    <!-- ✅ SHOW SCHEDULES BUTTON -->
                                    <a asp-controller="Schedule"
                                       asp-action="Index"
                                       asp-route-doctorId="@doctor.DoctorId"
                                       class="btn btn-info btn-sm ms-1">
                                        <i class="fas fa-calendar-alt"></i> Show Schedules
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            @if (doctor.Clinics.Any())
                            {
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5>Clinics:</h5>
                                    @if (Model.CurrentUserRole == "Doctor" && Model.CurrentUserId == doctor.DoctorId)
                                    {
                                        <a asp-action="CreateClinic" class="btn btn-success btn-sm">
                                            <i class="fas fa-plus"></i> Add New Clinic
                                        </a>
                                    }
                                </div>
                                @foreach (var clinic in doctor.Clinics)
                                {
                                    <div class="card mt-2">
                                        <div class="card-body">
                                            <h6 class="card-title">@clinic.Name</h6>
                                            <p class="card-text">
                                                <strong>📍 Location:</strong> @clinic.Location<br />
                                                <strong>📞 Phone:</strong> @clinic.Phone
                                            </p>

                                            @if (!string.IsNullOrEmpty(clinic.Description))
                                            {
                                                <div class="alert alert-light mt-2">
                                                    <strong><i class="fas fa-align-left"></i> Description:</strong>
                                                    <p class="mb-0 mt-1">@clinic.Description</p>
                                                </div>
                                            }

                                            @if (!string.IsNullOrEmpty(clinic.Schedule))
                                            {
                                                <div class="alert alert-info mt-2">
                                                    <strong><i class="fas fa-calendar-alt"></i> Working Hours:</strong>
                                                    <pre style="white-space: pre-wrap; margin-top: 8px; font-size: 13px; background: #f8f9fa; border-radius: 5px; padding: 8px;">@clinic.Schedule</pre>
                                                </div>
                                            }

                                            @if (clinic.CanEdit)
                                            {
                                                <div class="mt-2">
                                                    <a asp-action="EditClinic"
                                                       asp-route-id="@clinic.ClinicId"
                                                       class="btn btn-warning btn-sm">
                                                        <i class="fas fa-edit"></i> Edit Clinic
                                                    </a>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="d-flex justify-content-between align-items-center">
                                    <p class="text-muted mb-0">No clinics assigned yet.</p>
                                    @if (Model.CurrentUserRole == "Doctor" && Model.CurrentUserId == doctor.DoctorId)
                                    {
                                        <a asp-action="CreateClinic" class="btn btn-success btn-sm">
                                            <i class="fas fa-plus"></i> Add New Clinic
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p>No doctors found in the system.</p>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<style>
    .card-header {
        margin-bottom: 0;
    }

    .card {
        transition: transform 0.2s;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    .btn-warning:hover {
        background-color: #ffc107;
        transform: scale(1.02);
    }

    .btn-light:hover {
        transform: scale(1.02);
    }

    .btn-info:hover {
        transform: scale(1.02);
    }

    .btn-success:hover {
        transform: scale(1.02);
    }

    pre {
        font-family: monospace;
        font-size: 13px;
        margin: 0;
    }
</style>