@using System.Security.Claims
@model IEnumerable<AdaPET.Models.Animal>

@{
    ViewData["Title"] = "All Animals";
}

<h2>All Animals</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-4">
    <div class="row">
        @foreach (var animal in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(animal.ImgURL))
                    {
                        <img src="@animal.ImgURL" class="card-img-top" alt="@animal.Name" style="height: 200px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="bg-light text-center py-5">
                            <i class="fas fa-paw fa-3x text-muted"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title text-primary">@animal.Name</h5>
                        <p class="card-text">
                            <strong>Type:</strong> @animal.Type<br />
                            <strong>Age:</strong> @animal.Age years<br />
                            <strong>Status:</strong>
                            @if (animal.IsAdopted)
                            {
                                <span class="badge bg-danger">Adopted</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Available</span>
                            }
                        </p>
                        @if (!string.IsNullOrEmpty(animal.Description))
                        {
                            <p class="card-text">
                                <strong>Description:</strong> @animal.Description
                            </p>
                        }
                    </div>
                    <div class="card-footer bg-transparent">
                        <a asp-action="Details" asp-route-id="@animal.ID" class="btn btn-primary btn-sm">
                            <i class="fas fa-info-circle"></i> View Details
                        </a>
                        @{
                            var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                        }
                        @if (User.Identity.IsAuthenticated && userId == animal.OwnerId.ToString())
                        {
                            <a asp-action="Edit" asp-route-id="@animal.ID" class="btn btn-warning btn-sm">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <button type="button" class="btn btn-info btn-sm" onclick="deleteAnimal(@animal.ID)">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        <i class="fas fa-paw fa-3x mb-3"></i>
        <h5>No animals found</h5>
        <p>There are no animals registered in the system yet.</p>
    </div>
}

@section Scripts {
    <script>
        function deleteAnimal(id) {
            if (confirm('Are you sure you want to delete this animal?')) {
                var form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("Delete", "Animals")';

                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'id';
                input.value = id;

                var token = document.createElement('input');
                token.type = 'hidden';
                token.name = '__RequestVerificationToken';
                token.value = '@Html.AntiForgeryToken().ToString()';

                form.appendChild(input);
                form.appendChild(token);
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}

<style>
    .card {
        transition: transform 0.2s;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

    .btn-sm {
        margin: 2px;
    }
</style>