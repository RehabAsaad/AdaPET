@using System.Security.Claims
@model IEnumerable<AdaPET.Models.Animal>
@Html.AntiForgeryToken()

@{
    ViewData["Title"] = "All Animals";
    var currentFilter = ViewBag.CurrentFilter as string ?? "";
}

<style>
    /* تكبير هيدر الصفحة ليكون أوضح */
    .gallery-header-main {
        font-size: 2.5rem;
        font-weight: 800;
        color: #000000;
        margin-bottom: 30px;
        text-align: left;
        letter-spacing: -1px;
    }

    /* تنسيق بار البحث */
    .search-wrapper {
        position: relative;
        max-width: 500px;
        margin: 0 auto 40px auto;
    }

    .custom-search-bar {
        width: 100%;
        padding: 12px 20px 12px 45px;
        border-radius: 30px;
        border: 2px solid #e0e0e0;
        background-color: #fff;
        transition: all 0.3s ease;
        outline: none;
    }

    /* تنسيق الكروت */
    .animal-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s ease;
        background: white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .animal-image {
        height: 280px;
        position: relative;
    }

    .animal-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .status-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        z-index: 2;
    }

    .bg-available { background: #28a745; color: white; }
    .bg-adopted { background: #dc3545; color: white; }

    /* تنسيق الأزرار المفرغة (Outline) */
    .btn-custom-outline {
        padding: 8px 15px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        text-align: center;
        background-color: transparent;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-grow: 1;
    }

    .btn-outline-success-custom { border: 1px solid #28a745; color: #28a745; }
    .btn-outline-success-custom:hover { background-color: #28a745; color: white; }

    .btn-outline-primary-custom { border: 1px solid #007bff; color: #007bff; }
    .btn-outline-primary-custom:hover { background-color: #007bff; color: white; }

    .btn-outline-warning-custom { border: 1px solid #ffc107; color: #ffc107; }
    .btn-outline-warning-custom:hover { background-color: #ffc107; color: white; }

    .card-body-custom {
        padding: 20px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .type-badge {
        background-color: #f8f9fa;
        color: #007bff;
        border: 1px solid #dee2e6;
        padding: 4px 12px;
        border-radius: 15px;
        font-size: 0.85rem;
        font-weight: 600;
    }
</style>

<div class="container py-4">
    <div class="gallery-title-container">
        <h1 class="gallery-header-main d-flex align-items-center">
            <i class="fas fa-paw me-3 text-dark"></i> 
            Animal Gallery
        </h1>
    </div>

    <div class="search-wrapper">
        <form asp-action="Index" method="get">
            <input type="text" name="searchType" class="custom-search-bar" placeholder="Search for pets..." value="@currentFilter" />
        </form>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var animal in Model)
            {
                <div class="col-lg-4 col-md-6 col-sm-12">
                    <div class="animal-card">
                        <div class="animal-image">
                            <span class="status-badge @(animal.IsAdopted ? "bg-adopted" : "bg-available")">
                                @(animal.IsAdopted ? "Adopted" : "Available")
                            </span>
                            <img src="@animal.ImgURL" alt="@animal.Name">
                        </div>
                        <div class="card-body-custom">
                            <div>
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <h4 class="fw-bold text-dark mb-0">@animal.Name</h4>
                                    <span class="type-badge">@animal.Type</span>
                                </div>
                                
                                <div class="mb-2">
                                    <span class="text-muted small">
                                         Age: @animal.Age Years
                                    </span>
                                </div>

                                <p class="text-muted small mb-0">Find a loving home today.</p>
                            </div>

                            <div class="mt-4 pt-3 border-top">
                                @{ var userId = User.FindFirstValue(ClaimTypes.NameIdentifier); }
                                
                                <div class="d-flex align-items-center gap-2">
                                    @if (User.Identity.IsAuthenticated && userId == animal.OwnerId.ToString())
                                    {
                                        @if (!animal.IsAdopted)
                                        {
                                            <a asp-action="ToggleAdoptionStatus" asp-route-id="@animal.ID" class="btn-custom-outline btn-outline-success-custom shadow-sm">
                                                Mark as Adopted
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-action="ToggleAdoptionStatus" asp-route-id="@animal.ID" class="btn-custom-outline btn-outline-warning-custom shadow-sm">
                                                Make Available
                                            </a>
                                        }

                                        <div class="d-flex gap-2">
                                            <a asp-action="Edit" asp-route-id="@animal.ID" class="btn btn-sm btn-outline-warning rounded-circle shadow-sm" style="width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button type="button" onclick="deleteAnimal(@animal.ID)" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" style="width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        @if (!animal.IsAdopted)
                                        {
                                            <a asp-action="ContactOwner" asp-route-id="@animal.ID" class="btn-custom-outline btn-outline-primary-custom w-100 shadow-sm">
                                                Contact Owner
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary p-2 w-100" style="border-radius: 12px;">Already Adopted</span>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        @* الجزء الخاص في حال عدم وجود نتائج بحث *@
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="fas fa-search fa-5x text-muted opacity-50"></i>
            </div>
            <h2 class="fw-bold text-dark">No pets found!</h2>
            @if (!string.IsNullOrEmpty(currentFilter))
            {
                <p class="text-muted mb-4">We couldn't find any animals matching "@currentFilter".</p>
            }
            else
            {
                <p class="text-muted mb-4">The gallery is currently empty.</p>
            }
            
            <a asp-action="Index" class="btn btn-warning btn-lg px-5 fw-bold shadow-sm" style="border-radius: 30px;">
                <i class="fas fa-redo me-2"></i> View All Animals
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function deleteAnimal(id) {
            if (confirm('Are you sure you want to delete this record?')) {
                var form = document.createElement('form');
                form.method = 'POST';
                form.action = '/Animals/Delete/' + id;
                
                var token = $('input[name="__RequestVerificationToken"]').val();
                if (token) {
                    var tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = token;
                    form.appendChild(tokenInput);
                }

                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}