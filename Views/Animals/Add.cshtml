@model AdaPET.Models.Animal

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
                
                <div class="card-header border-0 text-white text-center py-4" style="background-color: #007bff;">
                    <h3 class="fw-bold mb-0">Add New Pet</h3>
                    <p class="mb-0 opacity-75 small">Fill in the information to list the pet</p>
                </div>

                <div class="card-body p-4">
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <form asp-action="Add" method="post" enctype="multipart/form-data">
                        
                        <input type="hidden" asp-for="ImgURL" value="temp" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label fw-bold small">Pet Name</label>
                                <input asp-for="Name" class="form-control" placeholder="e.g. Leo" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Type" class="form-label fw-bold">Animal Type *</label>
                                <select asp-for="Type" class="form-select shadow-sm" required>
                                    <option value="">-- Choose Type --</option>
                                    <option value="Dog">Dog</option>
                                    <option value="Cat">Cat</option>
                                    <option value="Bird">Bird</option>
                                    <option value="Rabbit">Rabbit</option>
                                    <option value="Hamster">Hamster</option>
                                    <option value="Turtle">Turtle</option>
                                    <option value="Parrot">Parrot</option>
                                    <option value="Fish">Fish</option>
                                    <option value="Horse">Horse</option>
                                    <option value="Monkey">Monkey</option>
                                </select>
                                <span asp-validation-for="Type" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Age" class="form-label fw-bold small">Age (In Years)</label>
                            <input asp-for="Age" class="form-control" type="number" min="0" />
                            <span asp-validation-for="Age" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold small">Health & Personality</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Description about the pet..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ImageFile" class="form-label fw-bold small">Pet Photo</label>
                            <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                            <span asp-validation-for="ImageFile" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 8px;">
                                Add Pet
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary w-50 py-2" style="border-radius: 8px;">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}