@model AdaPET.Models.Animal

<div class="container mt-5">
    <div class="row justify-content-center">

        <div class="col-lg-7 col-md-9">
            <div class="card shadow border-0" style="border-radius: 15px; overflow: hidden;">

                <!-- Header بنفس اللون الأزرق والمساحة -->
                <div class="card-header border-0 text-white text-center py-3" style="background-color: #007bff;">
                    <h3 class="fw-bold mb-1">Add New Animal</h3>
                    <p class="mb-0 opacity-75 small">Please fill in the details below to list your pet</p>
                </div>


                <div class="card-body p-4">
                    <form asp-action="Add" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="row mb-3">
                            <!-- Pet Name -->
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-bold small">Pet Name *</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text bg-light border-end-0" style="width: 35px;">🐾</span>
                                    <input asp-for="Name" class="form-control border-start-0" placeholder="e.g. Fluffy" required />
                                </div>
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <!-- Animal Type - ComboBox -->
                            <div class="col-md-6">
                                <label asp-for="Type" class="form-label fw-bold small">Animal Type *</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text bg-light border-end-0" style="width: 35px;">🐕</span>
                                    <input list="animalTypes" asp-for="Type" class="form-control border-start-0"
                                           placeholder="Select or type animal type" required />
                                </div>
                                <datalist id="animalTypes">
                                    <option value="Dog">🐕 Dog</option>
                                    <option value="Cat">🐈 Cat</option>
                                    <option value="Bird">🐦 Bird</option>
                                    <option value="Rabbit">🐇 Rabbit</option>
                                    <option value="Fish">🐟 Fish</option>
                                    <option value="Hamster">🐹 Hamster</option>
                                    <option value="Guinea Pig">🐹 Guinea Pig</option>
                                    <option value="Horse">🐎 Horse</option>
                                    <option value="Cow">🐄 Cow</option>
                                    <option value="Sheep">🐑 Sheep</option>
                                    <option value="Goat">🐐 Goat</option>
                                    <option value="Chicken">🐔 Chicken</option>
                                    <option value="Duck">🦆 Duck</option>
                                    <option value="Turtle">🐢 Turtle</option>
                                    <option value="Snake">🐍 Snake</option>
                                    <option value="Lizard">🦎 Lizard</option>
                                    <option value="Frog">🐸 Frog</option>
                                    <option value="Mouse">🐭 Mouse</option>
                                    <option value="Rat">🐀 Rat</option>
                                    <option value="Ferret">🐾 Ferret</option>
                                    <option value="Parrot">🦜 Parrot</option>
                                    <option value="Other">🐾 Other</option>
                                </datalist>
                                <small class="text-muted">Select from list or type your own</small>
                                <span asp-validation-for="Type" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Age (Years) -->
                        <div class="mb-3">
                            <label asp-for="Age" class="form-label fw-bold small">Age (Years) *</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light border-end-0" style="width: 35px;">📅</span>
                                <input asp-for="Age" class="form-control border-start-0" type="number" min="0" step="0.5" value="0" required />
                            </div>
                            <span asp-validation-for="Age" class="text-danger small"></span>
                        </div>

                        <!-- Health Status & Description -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold small">Health Status & Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3"
                                      placeholder="Tell us about the pet's health and personality..."></textarea>
                        </div>

                        <!-- Pet Photo -->
                        <div class="mb-3">
                            <label asp-for="ImageFile" class="form-label fw-bold small">Pet Photo</label>
                            <div class="input-group input-group-sm">
                                <label class="input-group-text bg-light" for="inputGroupFile01">📷 Choose File</label>
                                <input asp-for="ImageFile" type="file" class="form-control" id="inputGroupFile01" accept="image/*">
                            </div>
                            <small class="text-muted" style="font-size: 0.75rem;">Choose a clear photo of the animal (optional).</small>
                        </div>

                        <hr class="my-4 opacity-25">

                        <!-- الأزرار بنفس توزيع وألوان الصورة -->
                        <div class="d-flex justify-content-between">
                            <a asp-controller="UserProfile" asp-action="MyProfile" class="btn btn-outline-secondary btn-sm px-4 py-2" style="border-radius: 6px; color: #6c757d;">
                                ← Back to My Profile
                            </a>
                            <button type="submit" class="btn btn-primary btn-sm px-5 py-2 fw-bold" style="background-color: #0d6efd; border-radius: 6px;">
                                Add Pet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}